# ─── Sherlock — Environment Variables ─────────────────────
# Copy this file:  cp .env.example .env
# Then fill in your real values.
# ──────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL (used by pgvector container + app) ────────
POSTGRES_USER=sherlock_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sherlock_db
POSTGRES_PORT=5432

# For local dev this is 'localhost' (FastAPI connects to Docker DB via exposed port).
# In production Docker this is overridden to 'db' via .env.docker.
POSTGRES_HOST=localhost

# NOTE: DATABASE_URL is computed automatically by pydantic-settings.
# You do NOT need to set it manually.

# ── AWS / Amazon Bedrock ────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=us-east-1

BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0
