# ─── Sherlock — Production Docker Overrides ───────────────
# Used by docker-compose.prod.yml only.
# These override the defaults in core/config.py.
# ──────────────────────────────────────────────────────────

ENVIRONMENT=production

# Inside Docker network, the DB hostname is the service name 'db'.
POSTGRES_HOST=db
POSTGRES_USER=sherlock_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=sherlock_db
POSTGRES_PORT=5432
